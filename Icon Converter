#!/bin/zsh

# Made by Martin Widén 2026
# Icon Converter
# Converts all .icns files in a specified folder to .png

# ── Colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Colour

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
    echo "Usage: $(basename "$0") <folder>"
    echo ""
    echo "  Converts every .icns file found in <folder> to a .png file."
    echo "  The original .icns files are left untouched."
    echo ""
    echo "Example:"
    echo "  $(basename "$0") ~/Desktop/Icons"
    exit 1
}

# ── Argument validation ───────────────────────────────────────────────────────
if [[ $# -ne 1 ]]; then
    usage
fi

TARGET_DIR="$1"

if [[ ! -d "$TARGET_DIR" ]]; then
    echo "${RED}Error:${NC} '$TARGET_DIR' is not a valid directory." >&2
    exit 1
fi

# ── Output folder ────────────────────────────────────────────────────────────
OUTPUT_DIR="${TARGET_DIR}/Converted PNGs"
mkdir -p "$OUTPUT_DIR"

# ── Conversion ────────────────────────────────────────────────────────────────
converted=0
failed=0
skipped=0

echo "Scanning:  $TARGET_DIR"
echo "Output:    $OUTPUT_DIR"
echo "──────────────────────────────────────"

# Use glob to find .icns files (non-recursive); change ** to * for recursive
setopt nullglob
iscn_files=("$TARGET_DIR"/*.icns)

if [[ ${#iscn_files[@]} -eq 0 ]]; then
    echo "${YELLOW}No .icns files found in '$TARGET_DIR'.${NC}"
    exit 0
fi

for iscn_file in "${iscn_files[@]}"; do
    filename="$(basename "$iscn_file" .icns)"
    output_file="${OUTPUT_DIR}/${filename}.png"

    # Skip if a .png with the same name already exists
    if [[ -f "$output_file" ]]; then
        echo "  ${YELLOW}Skipped${NC}  $filename.icns  →  $filename.png already exists"
        (( skipped++ ))
        continue
    fi

    # sips is macOS-native and handles icns/png and many other formats
    if sips --setProperty format png "$iscn_file" --out "$output_file" &>/dev/null; then
        echo "  ${GREEN}Converted${NC} $filename.icns  →  $filename.png"
        (( converted++ ))
    else
        echo "  ${RED}Failed${NC}    $filename.icns  (sips could not convert this file)"
        (( failed++ ))
    fi
done

# ── Summary ───────────────────────────────────────────────────────────────────
echo "──────────────────────────────────────"
echo "Done.  ${GREEN}Converted: $converted${NC}  |  ${YELLOW}Skipped: $skipped${NC}  |  ${RED}Failed: $failed${NC}"
